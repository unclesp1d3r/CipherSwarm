# CipherSwarm Environment Variables
#
# Copy this file to `.env` and fill in the values for your deployment.
# See docs/deployment/environment-variables.md for comprehensive documentation.

# ==============================================================================
# CRITICAL - Required for Production
# ==============================================================================

# Rails master key for decrypting credentials (config/credentials.yml.enc)
# Obtain from config/master.key file (generated on first rails credentials:edit)
# SECURITY: Keep this secret! Anyone with this key can decrypt your credentials.
RAILS_MASTER_KEY=

# PostgreSQL database password
# SECURITY: Use a strong, randomly generated password (minimum 16 characters)
# Example: openssl rand -base64 32
POSTGRES_PASSWORD=

# Application host for URLs in emails, redirects, and Devise configuration
# Format: domain name without http:// prefix (e.g., cipherswarm.company.com)
# Impact: If missing, emails will have broken links, password reset will fail
APPLICATION_HOST=

# ==============================================================================
# IMPORTANT - Affects Production Behavior
# ==============================================================================

# Disable SSL enforcement (set to 'true' when behind reverse proxy handling SSL)
# Default: true (development), unset (production - SSL enforced)
# When to set: Behind nginx, HAProxy, or cloud load balancer
# When to leave unset: Direct Internet exposure with Rails handling SSL
DISABLE_SSL=true

# Storage backend selection
# Options: 'local' (default, Docker volumes) or 's3' (requires AWS_* variables)
# Default: local
ACTIVE_STORAGE_SERVICE=local

# Redis connection URL
# Default: redis://localhost:6379/0
# Docker: Use service name (e.g., redis://redis-db:6379/0)
# With auth: redis://:password@host:6379/0
# With TLS: rediss://host:6379/0
REDIS_URL=redis://redis-db:6379/0

# ==============================================================================
# OPTIONAL - Performance Tuning
# ==============================================================================

# Log verbosity level
# Options: debug, info (default), warn, error, fatal
# Production: info or warn (debug increases log volume significantly)
# RAILS_LOG_LEVEL=info

# Puma thread pool size per worker
# Default: 3
# Guidance: 5-10 for balanced throughput, increase for I/O-bound apps
# Important: DB connection pool must be >= RAILS_MAX_THREADS × WEB_CONCURRENCY
# RAILS_MAX_THREADS=3

# Number of Puma worker processes (multi-process for CPU utilization)
# Default: 1
# Guidance: 2-4 workers for production (1-2 per CPU core)
# Memory: Each worker uses ~200-300MB RAM
# WEB_CONCURRENCY=1

# Application listen port
# Default: 3000
# When to change: Port conflict or corporate firewall requirements
# PORT=3000

# Run Solid Queue background job processor inside Puma
# Default: unset (disabled, use separate Sidekiq process)
# Use for: Single-server deployments
# Don't use for: Multi-server production (use dedicated Sidekiq workers)
# Note: CipherSwarm currently uses Sidekiq, not Solid Queue
# SOLID_QUEUE_IN_PUMA=

# Puma PID file location
# Default: tmp/pids/server.pid (development), unset (production)
# When to set: Process monitoring, multiple Puma instances, systemd service
# PIDFILE=

# ==============================================================================
# S3 STORAGE - Required when ACTIVE_STORAGE_SERVICE=s3
# ==============================================================================

# S3 access key
# AWS S3: IAM access key
# MinIO: MINIO_ROOT_USER
# SeaweedFS: S3 gateway access key
# SECURITY: Never commit this to version control
# AWS_ACCESS_KEY_ID=

# S3 secret key
# AWS S3: IAM secret key
# MinIO: MINIO_ROOT_PASSWORD
# SeaweedFS: S3 gateway secret key
# SECURITY: Never commit this to version control
# AWS_SECRET_ACCESS_KEY=

# S3 endpoint URL (required for non-AWS S3-compatible services)
# MinIO: http://minio:9000
# SeaweedFS: http://seaweedfs:8333
# AWS S3: Leave unset (uses AWS endpoints)
# AWS_ENDPOINT=

# S3 bucket name
# Default: application
# Prerequisite: Bucket must exist before application starts
# AWS_BUCKET=application

# AWS region (or placeholder for S3-compatible services)
# Default: us-east-1
# MinIO/SeaweedFS: Required but not used (set to us-east-1)
# AWS_REGION=us-east-1

# Force path-style URLs (required for MinIO)
# Default: false
# MinIO: MUST be set to 'true'
# AWS S3: Leave at false (uses virtual-hosted-style)
# Path-style: http://s3.amazonaws.com/bucket/key
# Virtual-hosted: http://bucket.s3.amazonaws.com/key
# AWS_FORCE_PATH_STYLE=false

# ==============================================================================
# Common Configuration Scenarios
# ==============================================================================

# Scenario 1: Single-Server Docker (Local Storage)
# -------------------------------------------------
# RAILS_MASTER_KEY=<from-config/master.key>
# POSTGRES_PASSWORD=strongPassword
# APPLICATION_HOST=cipherswarm.company.com
# DISABLE_SSL=true
# ACTIVE_STORAGE_SERVICE=local
# REDIS_URL=redis://redis-db:6379/0

# Scenario 2: Multi-Server Docker (S3 Storage with MinIO)
# --------------------------------------------------------
# RAILS_MASTER_KEY=<from-config/master.key>
# POSTGRES_PASSWORD=strongPassword
# APPLICATION_HOST=cipherswarm.company.com
# DISABLE_SSL=true
# ACTIVE_STORAGE_SERVICE=s3
# REDIS_URL=redis://redis-db:6379/0
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_BUCKET=cipherswarm
# AWS_ENDPOINT=http://minio:9000
# AWS_FORCE_PATH_STYLE=true
# AWS_REGION=us-east-1
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=4

# Scenario 3: Air-Gapped Deployment (Local Storage)
# --------------------------------------------------
# RAILS_MASTER_KEY=<from-config/master.key>
# POSTGRES_PASSWORD=strongPassword
# APPLICATION_HOST=cipherswarm.local
# DISABLE_SSL=true
# ACTIVE_STORAGE_SERVICE=local
# REDIS_URL=redis://redis-db:6379/0

# Scenario 4: Development Environment
# ------------------------------------
# POSTGRES_PASSWORD=password
# APPLICATION_HOST=localhost
# RAILS_LOG_LEVEL=debug

# ==============================================================================
# For detailed documentation, see:
# docs/deployment/environment-variables.md
# ==============================================================================
