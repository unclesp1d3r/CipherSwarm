<div data-controller="tabs" data-tabs-active-value="0">
  <nav class="nav nav-tabs" role="tablist">
    <a href="#<%= panel_id('overview') %>"
       class="nav-link active"
       id="<%= tab_id('overview') %>"
       role="tab"
       aria-controls="<%= panel_id('overview') %>"
       aria-selected="true"
       tabindex="0"
       data-tabs-target="tab"
       data-action="click->tabs#switch keydown->tabs#keydown">Overview</a>
    <a href="#<%= panel_id('errors') %>"
       class="nav-link"
       id="<%= tab_id('errors') %>"
       role="tab"
       aria-controls="<%= panel_id('errors') %>"
       aria-selected="false"
       tabindex="-1"
       data-tabs-target="tab"
       data-action="click->tabs#switch keydown->tabs#keydown">Errors</a>
    <a href="#<%= panel_id('configuration') %>"
       class="nav-link"
       id="<%= tab_id('configuration') %>"
       role="tab"
       aria-controls="<%= panel_id('configuration') %>"
       aria-selected="false"
       tabindex="-1"
       data-tabs-target="tab"
       data-action="click->tabs#switch keydown->tabs#keydown">Configuration</a>
    <a href="#<%= panel_id('capabilities') %>"
       class="nav-link"
       id="<%= tab_id('capabilities') %>"
       role="tab"
       aria-controls="<%= panel_id('capabilities') %>"
       aria-selected="false"
       tabindex="-1"
       data-tabs-target="tab"
       data-action="click->tabs#switch keydown->tabs#keydown">Capabilities</a>
  </nav>

  <div class="tab-content mt-3">
    <div id="<%= panel_id("overview") %>"
         class="tab-pane active"
         role="tabpanel"
         data-tabs-target="panel"
         aria-labelledby="<%= tab_id("overview") %>">
      <%= overview_tab %>
    </div>

    <div id="<%= panel_id("errors") %>"
         class="tab-pane d-none"
         role="tabpanel"
         data-tabs-target="panel"
         aria-labelledby="<%= tab_id("errors") %>">
      <%= errors_tab %>
    </div>

    <div id="<%= panel_id("configuration") %>"
         class="tab-pane d-none"
         role="tabpanel"
         data-tabs-target="panel"
         aria-labelledby="<%= tab_id("configuration") %>">
      <%= configuration_tab %>
    </div>

    <div id="<%= panel_id("capabilities") %>"
         class="tab-pane d-none"
         role="tabpanel"
         data-tabs-target="panel"
         aria-labelledby="<%= tab_id("capabilities") %>">
      <%= capabilities_tab %>
    </div>
  </div>
</div>
