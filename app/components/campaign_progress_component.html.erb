<div class="row g-3 align-items-start" aria-label="Campaign progress">
  <div class="col-12 col-sm-7">
    <%= render(ProgressBarComponent.new(percentage: @percentage, label: @label)) %>
  </div>
  <div class="col-12 col-sm-5 d-flex flex-column gap-1">
    <span class="badge <%= status_class %> d-inline-flex align-items-center gap-1" aria-label="Status: <%= @status.humanize %>">
      <%= icon(status_icon) %>
      <span><%= @status.humanize %></span>
    </span>
    <span class="d-flex align-items-center gap-1 text-body-secondary" aria-label="Estimated time of arrival">
      <%= icon("clock") %>
      <span><%= formatted_eta %></span>
    </span>
    <small class="text-body-secondary" aria-label="Completion percentage"><%= formatted_percentage %></small>
  </div>
</div>
