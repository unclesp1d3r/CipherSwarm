<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title "Admin" %></h2>
    </div>
  </div>
</div>


<h3>Users</h3>
<% if can? :create, :user %>
  <div class="btn-group btn-group-sm" role="group" aria-label="User actions">
    <%= link_to new_user_path, class: "btn btn-primary", data: { turbo_frame: "remote_modal" } do %>
      <%= icon("plus-circle-fill") %>
      New User
    <% end %>
  </div>
<% end %>
<div class="table-responsive">
  <table class="table table-striped table-bordered table-sm">
    <thead>
    <tr>
      <th scope="col">id</th>
      <th scope="col">User Name</th>
      <th scope="col">Email</th>
      <th scope="col">Role</th>
      <th scope="col">Projects</th>
      <th scope="col">Last Login</th>
      <th scope="col">Actions</th>
    </tr>
    </thead>
    <tbody class="table-group-divider">
    <%= render partial: "user", collection: @users, cache: true %>
    </tbody>
  </table>
</div>
<h3>Projects</h3>
<% if can? :create, :project %>
  <div class="btn-group btn-group-sm" role="group" aria-label="Project actions">
    <%= link_to new_project_path, class: "btn btn-primary btn-sm" do %>
      <%= icon("plus-circle-fill") %>
      New Project
    <% end %>
  </div>
<% end %>
<div class="table-responsive">
  <table class="table table-striped table-bordered table-sm">
    <thead>
    <tr>
      <th scope="col">id</th>
      <th scope="col">Project Name</th>
      <th scope="col">Users</th>
      <th scope="col">Last Activity</th>
      <th scope="col">Actions</th>
    </tr>
    </thead>
    <tbody class="table-group-divider">
    <%= render partial: "project", collection: @projects, cache: true %>
    </tbody>
  </table>
</div>
