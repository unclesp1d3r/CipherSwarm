<div class="card">
  <div class="card-body">
    <nav aria-label="breadcrumb" class="mt-0 mb-1 fw-light">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
        <li class="breadcrumb-item active" aria-current="page">Agents</li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title "Agents" %></h2>
      <div>
        <% if can? :create, Agent %>
          <%= link_to new_agent_path, class: "btn btn-primary btn-sm", title: "New Agent" do %>
            <%= icon("plus-circle-fill") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= turbo_frame_tag "agents-cards", src: cards_agents_path, loading: (Rails.env.test? ? :eager : :lazy) do %>
  <div class="row g-4">
    <% 4.times do %>
      <div class="col-12 col-md-6 col-lg-4 col-xl-3">
        <%= render AgentStatusCardSkeletonComponent.new %>
      </div>
    <% end %>
  </div>
<% end %>
