<div class="card">
  <div class="card-body">
    <nav aria-label="breadcrumb" class="mt-0 mb-1 fw-light">
      <ol class="breadcrumb">
        <li class="breadcrumb-item active" aria-current="page">Activity</li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title "Activity" %></h2>
      <div>
        <% if can? :create, Campaign %>
          <%= link_to new_campaign_path, class: "btn btn-primary btn-sm", title: "New Campaign" do %>
            <%= icon("plus-circle-fill") %>
          <% end %>
        <% end %>
        <%= link_to toggle_hide_completed_activities_path, class: "btn btn-secondary btn-sm",
                                                           title: "Toggle completed item visibility", data: { turbo: false } do %>
          <%= current_user.hide_completed_activities? ? icon("eye-slash-fill") : icon("eye-fill") %>
        <% end %>
      </div>
    </div>
  </div>
</div>
<div class="d-flex gap-2 my-2">
  <%= link_to "All", campaigns_path,
        class: "btn btn-sm #{@filter.blank? ? 'btn-secondary' : 'btn-outline-secondary'}" %>
  <%= link_to "Quarantined", campaigns_path(filter: "quarantined"),
        class: "btn btn-sm #{@filter == 'quarantined' ? 'btn-danger' : 'btn-outline-danger'}" %>
</div>
<% if @campaigns.empty? %>
  <div class="text-center">
    <div class="mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-sticky" viewBox="0 0 16 16">
        <path d="M2.5 1A1.5 1.5 0 0 0 1 2.5v11A1.5 1.5 0 0 0 2.5 15h6.086a1.5 1.5 0 0 0 1.06-.44l4.915-4.914A1.5 1.5 0 0 0 15 8.586V2.5A1.5 1.5 0 0 0 13.5 1zM2 2.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 .5.5V8H9.5A1.5 1.5 0 0 0 8 9.5V14H2.5a.5.5 0 0 1-.5-.5zm7 11.293V9.5a.5.5 0 0 1 .5-.5h4.293z"/>
      </svg>
    </div>
    <h3>You do not have any campaigns.</h3>
    <p class="small text-secondary mt-3">Add a new campaign to get started.</p>
    <div class="mt-4">
      <%= link_to "Add a new campaign", new_campaign_path, class: "btn btn-primary" %>
    </div>
    <div class="small text-body-secondary mt-4">
      You also may need to verify your project roles and memberships with the project administrator.
    </div>
  </div>
<% else %>
  <div class="table-responsive">
    <table class="table table-striped table-sm">
      <thead>
      <tr>
        <th scope="col">Name</th>
        <th scope="col">Project</th>
        <th scope="col">Hash List</th>
        <th scope="col">Hashes</th>
        <th scope="col">Attacks</th>
        <th scope="col"><span class="visually-hidden">Actions</span></th>
      </tr>
      </thead>
      <tbody>
      <%= render partial: "campaign", collection: @campaigns, cache: true %>
      </tbody>
    </table>
  </div>
<% end %>
