<%# locals: @hash_list, @projects %>
<%= simple_form_for(@hash_list, html: { data: { controller: "direct-upload" } }) do |f| %>
  <% if @hash_list.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading"><%= pluralize(@hash_list.errors.count, "error") %> prevent this from saving.</h4>
      <ul>
        <% @hash_list.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="form-inputs">
    <%= f.input :name %>
    <%= f.input :description %>
    <%= f.input :file,
                input_html: { direct_upload: true, data: { direct_upload_target: "input" } } %>
    <div class="progress mt-2 d-none" data-direct-upload-target="progress">
      <div class="progress-bar progress-bar-striped progress-bar-animated"
           data-direct-upload-target="progressBar"
           role="progressbar"
           style="width: 0%"
           aria-valuenow="0"
           aria-valuemin="0"
           aria-valuemax="100"></div>
    </div>
    <p class="form-text mt-1" data-direct-upload-target="status"></p>
    <%= f.input :sensitive %>
    <%= f.association :project, collection: @projects, include_blank: false %>
    <%= f.association :hash_type,
        label_method: :to_s,
        include_blank: false,
        input_html: { data: { controller: "select" } } %>
  </div>
  <div class="form-actions">
    <%= f.button :submit, "Submit", class: "btn btn-primary", data: { direct_upload_target: "submit" } %>
    <%= link_to "Cancel", hash_lists_path, class: "btn btn-secondary" %>
  </div>
<% end %>
