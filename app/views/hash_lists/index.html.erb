<div class="card">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title "Hash lists" %></h2>
      <div>
        <% if can? :create, HashList %>
          <%= link_to new_hash_list_path, class: "btn btn-primary btn-sm", aria: { label: "New hash list" } do %>
            <%= icon("plus-circle-fill") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>


<div class="table-responsive">
<table class="table">
  <thead>
  <tr>
    <th scope="col">Name</th>
    <th scope="col">Description</th>
    <th scope="col">Hash Type</th>
    <th scope="col">Project</th>
    <th scope="col">Completion</th>
    <th scope="col"><span class="visually-hidden">Actions</span></th>
  </tr>
  </thead>
  <tbody>
  <%= render partial: "hash_list", collection: @hash_lists, cache: true %>
  </tbody>
</table>
</div>
