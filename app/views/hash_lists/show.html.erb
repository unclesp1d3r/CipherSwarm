<div class="card">
  <div class="card-body">
    <nav aria-label="breadcrumb" class="mt-0 mb-1 fw-light">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
        <li class="breadcrumb-item"><%= link_to "Hash Lists", hash_lists_path %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= @hash_list.name %></li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title @hash_list.name %></h2>
      <div>
        <% if can? :edit, @hash_list %>
          <%= link_to url_for([:edit, @hash_list]), class: "btn btn-warning btn-sm", aria: { label: "Edit hash list" } do %>
            <%= icon("pencil") %>
          <% end %>
          <%= link_to @hash_list, class: "btn btn-danger btn-sm", aria: { label: "Delete hash list" }, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } do %>
            <%= icon("trash") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= show_for @hash_list do |s| %>
  <%= s.attribute :name %>
  <%= s.attribute :description %>
  <%= s.association :hash_type %>
  <%= s.association :project %>
  <%= s.association :creator, label: "Created By" %>
<% end %>

<nav class="nav nav-tabs mt-4" aria-label="Hash item filters">
  <%= link_to "All", hash_list_path(@hash_list, item_state: "all"), class: "nav-link #{"active" if @state == "all"}", aria: (@state == "all" ? { current: "page" } : {}) %>
  <%= link_to "Cracked", hash_list_path(@hash_list, item_state: "cracked"), class: "nav-link #{"active" if @state == "cracked"}", aria: (@state == "cracked" ? { current: "page" } : {}) %>
  <%= link_to "Uncracked", hash_list_path(@hash_list, item_state: "uncracked"), class: "nav-link #{"active" if @state == "uncracked"}", aria: (@state == "uncracked" ? { current: "page" } : {}) %>
</nav>
<% if @hash_items.any? %>
  <div id="hash_items" aria-live="polite">
    <div>
      <%== @pagy.info_tag %>
    </div>
    <table class="table">
      <thead>
      <tr>
        <th scope="col">Hash</th>
        <th scope="col">Plain Text</th>
        <th scope="col">Metadata</th>
      </tr>
      </thead>
      <tbody>
      <% @hash_items.each do |hash_item| %>
        <%= turbo_stream_from hash_item %>
        <tr id="<%= dom_id(hash_item) %>">
          <td><%= hash_item.hash_value %></td>
          <td><%= hash_item.plain_text || "" %></td>
          <td>
            <% hash_item.metadata.each do |k, v| %>
              <strong><%= k %></strong>: <%= v %> <br>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>

    <% if @pagy.pages > 1 %>
      <%== @pagy.series_nav(:bootstrap) %>
      <noscript><%== @pagy.series_nav %></noscript>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info mt-4" role="alert">
    No hash items found.
  </div>
<% end %>
