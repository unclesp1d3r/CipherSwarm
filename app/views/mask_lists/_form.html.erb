<%= simple_form_for(@mask_list, html: { data: { controller: "direct-upload" } }) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :name %>
    <%= f.input :description %>
    <%= f.input :file,
                input_html: { direct_upload: true, data: { direct_upload_target: "input" } } %>
    <div class="progress mt-2 d-none" data-direct-upload-target="progress">
      <div class="progress-bar progress-bar-striped progress-bar-animated"
           data-direct-upload-target="progressBar"
           role="progressbar"
           style="width: 0%"
           aria-valuenow="0"
           aria-valuemin="0"
           aria-valuemax="100"></div>
    </div>
    <p class="form-text mt-1" data-direct-upload-target="status"></p>
    <%= f.input :sensitive %>
    <%= f.association :projects, as: :check_boxes, include_blank: false,
                                 collection: Project.accessible_by(current_ability) %>
  </div>

  <div class="form-actions btn-group">
    <%= f.button :submit, class: "btn btn-primary", data: { direct_upload_target: "submit" } %>
  </div>
<% end %>
