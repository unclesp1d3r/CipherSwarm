<%# locals: (resource_list:) -%>

<div class="card">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title resource_list.klass.model_name.human.pluralize %></h2>
      <div>
        <% if can? :create, resource_list.klass %>
          <%= link_to url_for(controller: controller_name, action: :new), class: "btn btn-primary btn-sm", aria: { label: "New #{resource_list.klass.model_name.human.downcase}" } do %>
            <%= icon("plus-circle-fill") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<table class="table">
  <thead>
    <tr>
      <th scope="col">Name</th>
      <th scope="col">Description</th>
      <th scope="col">Lines</th>
      <th scope="col">Estimated Complexity</th>
      <th scope="col">Sensitive</th>
      <th scope="col">Projects</th>
      <th scope="col"><span class="visually-hidden">Actions</span></th>
    </tr>
  </thead>
  <tbody>
    <% resource_list.each do |item| %>
      <tr>
        <td><%= item.name %></td>
        <td><%= truncate item.description %></td>
        <td><%= item.processed ? number_to_human(item.line_count) : "pending" %></td>
        <td><%= item.complexity_string %></td>
        <td><%= boolean_icon item.sensitive %></td>
        <td><%= truncate(item.projects.map(&:name).to_sentence) %></td>
        <td>
          <div class="btn-group btn-group-sm" role="group" aria-label="<%= item.name %> actions">
            <% if can? :read, item %>
              <%= link_to url_for(item), class: "btn btn-primary btn-sm", aria: { label: "View #{item.name}" } do %>
                <%= icon("eye") %>
              <% end %>
            <% end %>
            <% if can? :edit, item %>
              <%= link_to url_for([:edit, item]), class: "btn btn-warning btn-sm", aria: { label: "Edit #{item.name}" } do %>
                <%= icon("pencil") %>
              <% end %>
            <% end %>
            <% if can? :destroy, item %>
              <%= link_to item, method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger btn-sm", aria: { label: "Delete #{item.name}" } do %>
                <%= icon("trash") %>
              <% end %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
