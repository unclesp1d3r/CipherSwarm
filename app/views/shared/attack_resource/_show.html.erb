<%# locals: (resource:) -%>

<div class="card">
  <div class="card-body">
    <nav aria-label="breadcrumb" class="mt-0 mb-1 fw-light">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
        <li class="breadcrumb-item"><%= link_to resource.class.model_name.human.pluralize, url_for(controller: controller_name) %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= resource.name %></li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title resource.name %></h2>
      <div>
        <% if can? :edit, resource.class %>
          <%= link_to url_for([:edit, resource]), class: "btn btn-primary btn-sm" do %>
            <%= icon("pencil") %>
          <% end %>
          <%= link_to url_for([:view_file, resource]), class: "btn btn-secondary btn-sm" do %>
            <%= icon("file-earmark-binary") %>
          <% end %>
          <%= link_to url_for(resource), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" do %>
            <%= icon("trash") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= show_for resource do |s| %>
  <%= s.attribute :description %>
  <%= s.attribute :line_count %>
  <%= s.attribute :sensitive %>
  <%= s.association :projects %>
  <%= s.association :creator, label: "Created By" %>
<% end %>
