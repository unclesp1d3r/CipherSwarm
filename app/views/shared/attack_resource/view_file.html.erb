<div class="card">
  <div class="card-body">
    <nav aria-label="breadcrumb" class="mt-0 mb-1 fw-light">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
        <li class="breadcrumb-item"><%= link_to @resource.class.model_name.human.pluralize, "#" %></li>
        <li class="breadcrumb-item"><%= link_to @resource.name, @resource %></li>
        <li class="breadcrumb-item active" aria-current="page">View File Contents</li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= title @resource.name %></h2>
      <div>
        <% if can? :create, WordList %>
          <%= link_to url_for([:download, @resource]), class: "btn btn-primary btn-sm" do %>
            <%= icon("download") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
<div class="row">
<div class="col-12 col-lg-9">
<div class="card">
  <div class="card-body">
    <p class="text-muted small mb-2">Showing first <%= number_with_delimiter(@effective_limit) %> lines of file.</p>
    <p class="card-text">
      <%= turbo_frame_tag :file_content, src: url_for([:view_file_content, @resource, { limit: @effective_limit, only_path: true }]), loading: :lazy do %>
        Loading...
      <% end %>
    </p>
  </div>
</div>
</div>
</div>
