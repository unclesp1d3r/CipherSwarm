#!/bin/sh -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Run database migrations only when explicitly requested via RUN_DB_PREPARE=true.
# In scaled deployments (multiple web replicas), running db:prepare from every
# container causes migration races and deadlocks. Instead, run migrations as a
# one-shot command before starting replicas:
#   docker compose run --rm -e RUN_DB_PREPARE=true web ./bin/rails db:prepare
if [ "${RUN_DB_PREPARE:-false}" = "true" ]; then
  ./bin/rails db:prepare
fi

exec "$@"
